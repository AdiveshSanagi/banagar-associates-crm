# ==========================================
# 1. PYTHON & VIRTUAL ENVIRONMENT
# ==========================================
# Completely ignore the massive virtual environment folder
.venv/
venv/
env/

# Ignore Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================
# 2. SECURITY & SECRETS (CRITICAL)
# ==========================================
# Never upload your real passwords, JWT secrets, or database URLs!
.env
backend/.env
*.env

# ==========================================
# 3. USER UPLOADS & LOCAL MEDIA
# ==========================================
# Keep the uploads folder structure, but ignore the actual images/videos inside it
backend/uploads/*
!backend/uploads/.gitkeep

# ==========================================
# 4. OS & EDITOR FILES
# ==========================================
# Ignore annoying hidden files generated by Macs/Windows or VS Code
.DS_Store
Thumbs.db
.vscode/
.idea/

# ==========================================
# 5. LOGS & LOCAL DATABASES (NEW)
# ==========================================
# Prevent application logs and local test databases from uploading
*.log
*.sqlite3
*.db